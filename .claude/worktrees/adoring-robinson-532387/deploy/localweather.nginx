server {
    listen 80;
    server_name _;

    access_log /var/log/nginx/localweather.access.log;
    error_log  /var/log/nginx/localweather.error.log;

    # Serve static files directly — no gunicorn round-trip
    location /static/ {
        alias /opt/localweather/static/;
        expires 1h;
        add_header Cache-Control "public";
    }

    location / {
        proxy_pass http://unix:/run/localweather/gunicorn.sock;
        proxy_set_header Host              $host;
        proxy_set_header X-Real-IP         $remote_addr;
        proxy_set_header X-Forwarded-For   $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_read_timeout 30s;
    }

    gzip on;
    gzip_types text/css application/javascript application/json text/plain;
}
