[Unit]
Description=LocalWeather Flask app (gunicorn)
After=network.target

[Service]
User=localweather
Group=localweather
WorkingDirectory=/opt/localweather
ExecStart=/opt/localweather/.venv/bin/gunicorn \
    --workers 2 \
    --bind unix:/run/localweather/gunicorn.sock \
    --access-logfile /var/log/localweather/access.log \
    --error-logfile /var/log/localweather/error.log \
    app:app
RuntimeDirectory=localweather
RuntimeDirectoryMode=0755
Restart=on-failure
RestartSec=5

[Install]
WantedBy=multi-user.target
